# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/build/
/android/app/debug
/android/app/profile
/android/app/release
/android/.kotlin/

# Release signing & store secrets — NEVER commit these.
# (Android key.properties / *.jks / *.keystore are covered by android/.gitignore.)
**/*.p8
**/*.p12
**/*.mobileprovision
**/*.cer
# fastlane working files & credentials
**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/.env*
ios/fastlane/*.p8
# Google Play service-account key for fastlane supply
android/fastlane/play-service-account.json
# Obfuscation symbol output from the build scripts
/build/symbols/
