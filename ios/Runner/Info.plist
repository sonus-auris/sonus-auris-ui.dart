<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Sonus Auris</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Sonus Auris</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- Make the secure default explicit and audit-proof: no plaintext HTTP,
		     no per-domain exceptions. All backend / S3 / OAuth traffic is HTTPS. -->
		<key>NSAllowsArbitraryLoads</key>
		<false/>
	</dict>
	<key>NSMicrophoneUsageDescription</key>
	<string>Sonus Auris records a rolling audio window only after you start capture.</string>
	<key>NSMotionUsageDescription</key>
	<string>During a sleep session Sonus Auris reads motion to detect stillness, tossing, and getting up, improving sleep-cycle accuracy. This is optional and off by default.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Sonus Auris can tag recordings with their location so a clip can prove where it was captured. Location tagging is optional and off by default.</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Sonus Auris can notice Bluetooth and nearby devices to offer to start a scheduled recording. This is optional and off by default.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>Sonus Auris can notice Bluetooth and nearby devices to offer to start a scheduled recording. This is optional and off by default.</string>
	<!-- Export compliance: only standard, published crypto (TLS; AES-256-GCM with
	     HKDF/Argon2id for on-device data protection), no proprietary/non-standard
	     encryption, so the app qualifies for the encryption exemption and uploads
	     skip the per-build export prompt. See docs/compliance/EXPORT_COMPLIANCE.md;
	     change to <true/> if you add non-exempt cryptography. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>UIWindowScene</string>
					<key>UISceneConfigurationName</key>
					<string>flutter</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<!-- OAuth redirect scheme for flutter_web_auth_2 (Spotify/SoundCloud account
	     linking). The app opens sonusauris://oauth/callback via ASWebAuthentication;
	     registering the scheme lets the redirect return into the app. PKCE + a
	     validated state param protect the flow (see oauth_browser.dart). -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.ores.audioDashcam.oauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>sonusauris</string>
			</array>
		</dict>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<!-- Advertised by flutter_foreground_task's native iOS registration. The
	     capture path itself uses the audio background mode above. -->
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.pravera.flutter_foreground_task.refresh</string>
	</array>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
