<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Private app-scoped Keychain storage for credentials and encryption keys. -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	</array>
	<!--
	  iCloud Documents capability for the audio_dashcam/icloud bridge.
	  The matching iCloud container must exist in the Apple Developer account.
	  Release/Profile builds use this file; simulator Debug uses the smaller
	  RunnerBase.entitlements so development does not require portal capabilities.
	-->
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array>
		<string>iCloud.com.ores.audioDashcam</string>
	</array>
	<key>com.apple.developer.icloud-services</key>
	<array>
		<string>CloudDocuments</string>
	</array>
	<key>com.apple.developer.ubiquity-container-identifiers</key>
	<array>
		<string>iCloud.com.ores.audioDashcam</string>
	</array>
	<!--
	  ShazamKit capability for the audio_dashcam/shazam bridge (song id when the
	  user enables it). Enable "ShazamKit" on the App ID in the Apple Developer
	  portal; Xcode adds this entitlement when the capability is turned on. Song
	  identification simply fails soft (returns no match) without it.
	-->
	<key>com.apple.developer.shazamkit</key>
	<true/>
	<!--
	  Access WiFi Information capability for the Wi-Fi context trigger (reading the
	  joined SSID to detect home/away changes). Enable "Access WiFi Information" on
	  the App ID in the Apple Developer portal. Without it (and location
	  permission) the SSID reads as null and the Wi-Fi trigger simply fails soft —
	  the connectivity (network-change) trigger is unaffected.
	-->
	<key>com.apple.developer.networking.wifi-info</key>
	<true/>
</dict>
</plist>
