# fastlane Appfile (iOS). https://docs.fastlane.tools/app-store-connect-api/
app_identifier("com.ores.audioDashcam")

# Prefer an App Store Connect API key (.p8) over Apple-ID/password auth. These
# settings are optional with API-key auth and must come from the environment —
# never commit account identifiers as placeholders that can reach a release job.
apple_id(ENV["APPLE_ID"]) if ENV["APPLE_ID"]
team_id(ENV["DEVELOPMENT_TEAM"]) if ENV["DEVELOPMENT_TEAM"]
itc_team_id(ENV["ASC_TEAM_ID"]) if ENV["ASC_TEAM_ID"]
